-- HISTORY
local historyFrame = Instance.new("ScrollingFrame", frame)
historyFrame.Size = UDim2.new(1,-20,0,120)
historyFrame.Position = UDim2.new(0,10,0,260)
historyFrame.BackgroundColor3 = Color3.fromRGB(15,15,20)
Instance.new("UICorner", historyFrame)

local lay = Instance.new("UIListLayout", historyFrame)
lay.Padding = UDim.new(0,3)

local function refreshHistory()
    for _,v in pairs(historyFrame:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,txt in ipairs(data.history) do
        local b = Instance.new("TextButton", historyFrame)
        b.Size = UDim2.new(1,-6,0,24)
        b.Text = "   "..txt
        b.BackgroundColor3 = Color3.fromRGB(20,20,30)
        b.TextColor3 = Color3.fromRGB(200,200,255)

        b.MouseButton1Click:Connect(function()
            box.Text = txt
            data.text = txt
        end)
    end
end

local function addHistory(text)
    for i,v in ipairs(data.history) do
        if v == text then table.remove(data.history,i) break end
    end
    table.insert(data.history,1,text)
    if #data.history > 10 then table.remove(data.history) end
    saveHistory()
    refreshHistory()
end

refreshHistory()

