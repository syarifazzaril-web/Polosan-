box.TextColor3 = Color3.fromRGB(230,230,255)
box.TextXAlignment = Enum.TextXAlignment.Left
box.ClearTextOnFocus = false
box.Text = data.text

local isTyping = false
box.Focused:Connect(function() isTyping = true end)
box.FocusLost:Connect(function()
    isTyping = false
    data.text = cap(box.Text)
    box.Text = data.text
end)

-- AUTOCOMPLETE
local suggest = Instance.new("ScrollingFrame", frame)
suggest.Size = UDim2.new(1,-20,0,0)
suggest.Position = UDim2.new(0,10,0,85)
suggest.BackgroundColor3 = Color3.fromRGB(15,15,25)
Instance.new("UICorner", suggest)

local layout = Instance.new("UIListLayout", suggest)

layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    suggest.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
    suggest.Size = UDim2.new(1,-20,0,math.clamp(layout.AbsoluteContentSize.Y,0,80))
end)

local function updateSuggest(t)
    for _,v in pairs(suggest:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    local count = 0
    for _,n in ipairs(data.indexCache) do
        if n:lower():find(t:lower()) then
            count += 1
            if count > 8 then break end

            local b = Instance.new("TextButton", suggest)
            b.Size = UDim2.new(1,-6,0,22)
            b.Text = "   "..n
            b.BackgroundColor3 = Color3.fromRGB(25,25,35)
            b.TextColor3 = Color3.fromRGB(200,200,255)

            b.MouseButton1Click:Connect(function()
                box.Text = n
                data.text = n
            end)
        end
    end
end

box:GetPropertyChangedSignal("Text"):Connect(function()
    if isTyping then
        local cur = box.CursorPosition
        local new = cap(box.Text)

        if new ~= box.Text then
            box.Text = new
            box.CursorPosition = cur
        end

        data.text = box.Text
        updateSuggest(box.Text)
    end
end)

