-- QUEUE
task.spawn(function()
    while true do
        if #data.queue > 0 then
            local job = table.remove(data.queue,1)
            game:GetService("ReplicatedStorage")
                :WaitForChild("Events")
                :WaitForChild("RewardEscape")
                :FireServer(job.name, job.type, job.rarity)
            task.wait(0.1)
        else
            task.wait(0.2)
        end
    end
end)

-- NOTIF
local notif = Instance.new("TextLabel", gui)
notif.Size = UDim2.new(0,250,0,40)
notif.Position = UDim2.new(0.5,-125,0,20)
notif.Visible = false
Instance.new("UICorner", notif)

local function showNotif(text, color)
    notif.Text = text
    notif.BackgroundColor3 = color
    notif.TextColor3 = Color3.new(1,1,1)
    notif.Visible = true
    task.delay(2,function() notif.Visible = false end)
end

local function checkInventory(name)
    local p = game.Players.LocalPlayer
    local bp = p:FindFirstChild("Backpack")
    if bp then
        for _,v in pairs(bp:GetChildren()) do
            if v.Name == name then return true end
        end
    end
    return false
end

-- CONFIRM
confirm.MouseButton1Click:Connect(function()
    local name = data.text
    local amt = tonumber(amount.Text)
    if not name or not amt then return end

    for i=1,amt do
        table.insert(data.queue,{
            name=name,
            type=types[tIndex],
            rarity=rarities[rIndex]
        })
    end

    addHistory(name)

    popup.Visible=false
    frame.Visible=true

    task.spawn(function()
        task.wait(2)
        if checkInventory(name) then
            showNotif("✅ Sukses: "..name, Color3.fromRGB(20,80,40))
        else
            showNotif("❌ Failed: "..name, Color3.fromRGB(80,20,20))
        end
    end)
end)

