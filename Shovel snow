-- [[ Rilzz Hub ]] --
-- TAB: SHOVEL SNOW FOR BRAINROT

local lib = _G.RilzHub
local ShovelSnow = lib:AddTab("SHOVEL SNOW FOR BRAINROT")
local RS = game:GetService("ReplicatedStorage")
local Remotes = RS:WaitForChild("Remotes")

lib:AddToggle(ShovelSnow.scroll, "Auto Buy Damage", "Otomatis beli upgrade Damage", false, function(Value)
    _G.AutoBuyDamage = Value
    if Value then
        task.spawn(function()
            while _G.AutoBuyDamage do
                Remotes:WaitForChild("BuyUpgradeEvent"):FireServer("Damage", 500)
                task.wait(0.001)
            end
        end)
    end
end)

lib:AddToggle(ShovelSnow.scroll, "Auto Upgrade Brainrot", "Otomatis upgrade brainrot", false, function(Value)
    _G.AutoUpgradeBrainrot = Value
    if Value then
        task.spawn(function()
            while _G.AutoUpgradeBrainrot do
                Remotes:WaitForChild("UpgradeBrainrotEvent"):FireServer(1)
                task.wait(0.01)
            end
        end)
    end
end)

lib:AddToggle(ShovelSnow.scroll, "Auto Rebirth", "Otomatis Rebirth", false, function(Value)
    _G.AutoRebirthSnow = Value
    if Value then
        task.spawn(function()
            while _G.AutoRebirthSnow do
                Remotes:WaitForChild("RebirthEvent"):FireServer()
                task.wait(0.1)
            end
        end)
    end
end)
