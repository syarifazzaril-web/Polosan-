-- [[ 5. CORE LOGIC ]] --
local function StripRichText(text) return string.gsub(text, "<[^>]+>", "") end

local function ClickPickUp()
    pcall(function()
        for _, g in pairs(player.PlayerGui:GetDescendants()) do
            if g:IsA("TextButton") or g:IsA("ImageButton") then
                local lbl = g:FindFirstChildWhichIsA("TextLabel")
                local txt = lbl and string.lower(lbl.Text) or ""
                local nm = string.lower(g.Name)
                if string.find(txt, "pick") or string.find(nm, "pick") then
                    if firesignal then 
                        firesignal(g.MouseButton1Down)
                        firesignal(g.MouseButton1Click)
                        firesignal(g.MouseButton1Up)
                    end
                    for _, con in pairs(getconnections(g.MouseButton1Click)) do 
                        con:Function() 
                    end
                end
            end
        end
    end)
end

-- [ Thread 1: Player Mods ]
RunService.Stepped:Connect(function()
    pcall(function()
        local char = player.Character
        if char then
            if IsNoclip then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
            local hum = char:FindFirstChild("Humanoid")
            if IsFastWalk and hum then
                hum.WalkSpeed = CustomSpeed
            end
        end
    end)
end)

-- [ Thread 2: AUTO FARM BRAINROTS ]
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if not IsAutoFarm then return end
            
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not root then return end 
            
            local brainrotsFolder = Workspace:FindFirstChild("Brainrots")
            if not brainrotsFolder then return end

            local targetPart = nil

            for _, brainrot in pairs(brainrotsFolder:GetChildren()) do
                local isRightRarity = false
                local isReal = false
                local isSteal = false 
                
                for _, desc in pairs(brainrot:GetDescendants()) do
                    if desc:IsA("TextLabel") then
                        local txt = string.lower(StripRichText(desc.Text))
                        
                        if string.match(txt, "%f[%w]" .. string.lower(CurrentRarity) .. "%f[%W]") then
                            isRightRarity = true
                        end
                        if string.find(txt, "%$") or string.find(txt, "/s") then
                            isReal = true
                        end
                        if string.find(txt, "steal") then
                            isSteal = true
                        end
                    elseif desc:IsA("ProximityPrompt") then
                        local a = string.lower(desc.ActionText)
                        local o = string.lower(desc.ObjectText)
                        if string.find(a, "steal") or string.find(o, "steal") then
                            isSteal = true
                        end
                    end
                end
                
                if isRightRarity and isReal and not isSteal then
                    targetPart = brainrot.PrimaryPart or brainrot:FindFirstChildWhichIsA("BasePart")
                    if targetPart then break end
                end
            end

            if targetPart then
                root.CFrame = targetPart.CFrame * CFrame.new(0, 0, 0)
                
                if firetouchinterest then
                    firetouchinterest(root, targetPart, 0)
                    task.wait(0.01)
                    firetouchinterest(root, targetPart, 1)
                end
                
                task.wait(0.25)
                local prompt = targetPart.Parent:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then fireproximityprompt(prompt) end
                
                ClickPickUp()
                task.wait(0.3) 
                
                if OriginalPos then root.CFrame = OriginalPos end
                task.wait(0.2)
            end
        end)
    end
end)

-- [ Thread 3: Auto Collect Money & Remotes (FAST CACHE SYSTEM) ]
local cachedCollectParts = {}
local lastCacheUpdate = 0

task.spawn(function()
    while task.wait(0.2) do
        pcall(function()
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            
            -- อัปเดตแผ่นเก็บเงิน
            if CollectSettings.AutoMoney and root then
                if os.clock() - lastCacheUpdate > 15 or #cachedCollectParts == 0 then
                    table.clear(cachedCollectParts)
                    for _, folderName in ipairs({"Bases", "Platforms"}) do
                        local folder = Workspace:FindFirstChild(folderName)
                        if folder then
                            for _, v in pairs(folder:GetDescendants()) do
                                if v.Name == "Collect" and v:IsA("BasePart") then
                                    table.insert(cachedCollectParts, v)
                                end
                            end
                        end
                    end
                    lastCacheUpdate = os.clock()
                end
                
                for _, part in ipairs(cachedCollectParts) do
                    if firetouchinterest and part.Parent then
                        firetouchinterest(root, part, 0)
                        firetouchinterest(root, part, 1)
                    end
                end
            end
            
            -- ระบบอัปเกรด (ตาม Request ใหม่)
            local rem = ReplicatedStorage:FindFirstChild("Remotes")
            if rem and rem:FindFirstChild("BuyUpgradeEvent") then
                if CollectSettings.AutoRebirth and rem:FindFirstChild("RebirthEvent") then 
                    rem.RebirthEvent:FireServer() 
                end
                
                -- Damage
                if CollectSettings.AutoDmg100 then rem.BuyUpgradeEvent:FireServer("Damage", 100) end
                if CollectSettings.AutoDmg500 then rem.BuyUpgradeEvent:FireServer("Damage", 500) end
                
                -- Speed
                if CollectSettings.AutoSpeed1 then rem.BuyUpgradeEvent:FireServer("Speed", 1) end
                if CollectSettings.AutoSpeed5 then rem.BuyUpgradeEvent:FireServer("Speed", 5) end
                
                -- Carry
                if CollectSettings.AutoCarry then rem.BuyUpgradeEvent:FireServer("Carry", 1) end
            end
        end)
    end
end)
