-- ============ LOGIC ============
local lockedCoord = nil
local hasAutoTP = false

task.spawn(function()
    local char = lp.Character or lp.CharacterAdded:Wait()
    char:WaitForChild("HumanoidRootPart")
    local dist
    lockedCoord, dist = getNearestCoord()
    if lockedCoord then
        CoordName.Text = "🔒 " .. lockedCoord.name
        CoordVal.Text = string.format("X: %.2f   Z: %.2f", lockedCoord.x, lockedCoord.z)
        DistLabel.Text = string.format("%.1f stud", dist)
        StatusText.Text = "Terkunci ke " .. lockedCoord.name .. " — tidak akan berubah"
        StatusText.TextColor3 = Color3.fromRGB(90, 170, 120)
    end
end)

local function doAutoTP()
    if not lockedCoord then return end
    if hasAutoTP then return end
    hasAutoTP = true
    StatusDot.BackgroundColor3 = Color3.fromRGB(40, 200, 100)
    StatusText.Text = "⚡ TP ke " .. lockedCoord.name .. "!"
    StatusText.TextColor3 = Color3.fromRGB(90, 200, 150)
    teleportTo(lockedCoord)
    task.wait(1)
    hasAutoTP = false
    StatusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
    StatusText.Text = "✅ Siap steal berikutnya"
    StatusText.TextColor3 = Color3.fromRGB(90, 170, 120)
end

-- ============ AUTO DETECT PROGRESS ============
task.spawn(function()
    task.wait(2)

    local isRunning = false

    local function hookProgress(v)
        warn("Progress hooked: " .. v:GetFullName())
        StatusDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        StatusText.Text = "✅ Progress terdeteksi — siap auto TP"
        StatusText.TextColor3 = Color3.fromRGB(90, 170, 120)

        v:GetPropertyChangedSignal("Value"):Connect(function()
            if v.Value <= 0 and not isRunning then
                isRunning = true
                doAutoTP()
                task.wait(1)
                isRunning = false
            end
        end)
    end

    for _, v in ipairs(game:GetDescendants()) do
        if v.Name == "Progress" and (v:IsA("NumberValue") or v:IsA("IntValue")) then
            hookProgress(v)
        end
    end

    game.DescendantAdded:Connect(function(v)
        if v.Name == "Progress" and (v:IsA("NumberValue") or v:IsA("IntValue")) then
            hookProgress(v)
        end
    end)
end)

