-- Rilzz Hub - SC Kick Script
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Rilzz Hub",
    LoadingTitle = "Rilzz Hub",
    LoadingSubtitle = "by Rilzz",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

local Tab = Window:CreateTab("Main", 4483362458)

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local finalPosition = Vector3.new(708.052, 3.167, 188.172)
local detecting = false
local moveConnection
local toolConnection
local isRunning = false
local isEnabled = false

local function stopAll()
    detecting = false
    isRunning = false
    if moveConnection then moveConnection:Disconnect() moveConnection = nil end
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
end

local function runSequence()
    if isRunning then return end
    if not isEnabled then return end
    isRunning = true
    detecting = false

    if moveConnection then moveConnection:Disconnect() moveConnection = nil end
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end

    rootPart.CFrame = CFrame.new(Vector3.new(699.768, 3.167, 231.199))
    task.wait(0.35)

    local args = { [1] = 1 }
    game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("rev_KickEvent"):FireServer(unpack(args))
    rootPart.CFrame = CFrame.new(Vector3.new(-2643.9912109375, 49.99802017211914, 157.18048095703125))

    task.wait(14)

    if not isEnabled then isRunning = false return end

    rootPart.CFrame = CFrame.new(Vector3.new(714.386, 3.167, 167.385))
    task.wait(0.1)

    local tween = TweenService:Create(rootPart, TweenInfo.new(1, Enum.EasingStyle.Linear), {CFrame = CFrame.new(finalPosition)})
    tween:Play()
    tween.Completed:Wait()

    if not isEnabled then isRunning = false return end

    detecting = true
    isRunning = false

    local lastPosition = rootPart.Position

    moveConnection = RunService.Heartbeat:Connect(function()
        if not detecting then return end
        local dist = (rootPart.Position - lastPosition).Magnitude
        if dist > 0.01 then
            rootPart.CFrame = CFrame.new(finalPosition)
        end
        lastPosition = rootPart.Position
    end)

    toolConnection = character.ChildAdded:Connect(function(child)
        if not detecting then return end
        if not isEnabled then return end
        if child:IsA("Tool") then
            detecting = false
            if moveConnection then moveConnection:Disconnect() moveConnection = nil end
            toolConnection:Disconnect() toolConnection = nil
            task.spawn(runSequence)
        end
    end)
end

Tab:CreateToggle({
    Name = "Auto Perfect And Claim",
    CurrentValue = false,
    Flag = "AutoPerfectClaim",
    Callback = function(value)
        isEnabled = value
        if isEnabled then
            task.spawn(runSequence)
        else
            stopAll()
        end
    end,
})

Rayfield:LoadConfiguration()
