-- Rilzz Hub - SC Kick Script
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Rilzz Hub",
    LoadingTitle = "Rilzz Hub",
    LoadingSubtitle = "by Rilzz",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

local Tab = Window:CreateTab("Main", 4483362458)

local player = game.Players.LocalPlayer

-- Fungsi ambil karakter terbaru
local function getCharacter()
    local character = player.Character or player.CharacterAdded:Wait()
    local rootPart = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    return character, rootPart, humanoid
end

local finalPosition = Vector3.new(703.29931640625, 11.34885025024414, 214.4062957763672)
local startPosition = Vector3.new(699.768, 3.167, 231.199)
local afterKickPosition = Vector3.new(-2643.9912109375, 49.99802017211914, 157.18048095703125)

local detecting = false
local toolConnection
local isRunning = false
local isEnabled = false

local function stopAll()
    detecting = false
    isRunning = false
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
    -- Force unfreeze karakter terbaru
    local _, _, humanoid = getCharacter()
    humanoid.WalkSpeed = 16
    humanoid.JumpPower = 50
end

local function safeTeleport(rootPart, pos, timeout)
    rootPart.CFrame = CFrame.new(pos)
    local waited = 0
    repeat
        task.wait(0.05)
        waited += 0.05
        if not isEnabled then return end
    until (rootPart.Position - pos).Magnitude < 5 or waited >= (timeout or 2)
end

local function safeWait(seconds)
    for i = 1, seconds do
        task.wait(1)
        if not isEnabled then return false end
    end
    return true
end

local function onToolDetected(character, rootPart)
    if not detecting then return end
    if not isEnabled then return end
    detecting = false
    if toolConnection then toolConnection:Disconnect() toolConnection = nil end
    task.spawn(function()
        task.wait(0.2)
        if isEnabled then
            task.spawn(runSequence)
        end
    end)
end

function runSequence()
    if isRunning then return end
    if not isEnabled then return end
    isRunning = true
    detecting = false

    if toolConnection then toolConnection:Disconnect() toolConnection = nil end

    -- Ambil karakter terbaru setiap kali loop mulai
    local character, rootPart, humanoid = getCharacter()

    -- STEP 1: Teleport ke start
    safeTeleport(rootPart, startPosition, 2)
    if not isEnabled then isRunning = false return end
    task.wait(0.4)
    if not isEnabled then isRunning = false return end

    -- STEP 2: Fire kick event
    local args = { [1] = 1 }
    game:GetService("ReplicatedStorage")
        :WaitForChild("Shared")
        :WaitForChild("Packages")
        :WaitForChild("Network")
        :WaitForChild("rev_KickEvent")
        :FireServer(unpack(args))

    safeTeleport(rootPart, afterKickPosition, 2)
    if not isEnabled then isRunning = false return end

    -- STEP 3: Wait 16 detik
    local ok = safeWait(16)
    if not ok or not isEnabled then isRunning = false return end

    -- Ambil karakter lagi setelah respawn dari kick
    character, rootPart, humanoid = getCharacter()

    -- STEP 4: Aktifkan detecting
    detecting = true
    isRunning = false

    -- Listen tool
    toolConnection = character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            onToolDetected(character, rootPart)
        end
    end)

    -- Race condition check
    task.spawn(function()
        task.wait(0.15)
        if not detecting then return end
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") then
                onToolDetected(character, rootPart)
                return
            end
        end
    end)

    -- Loop TP ke finalPosition tiap 0.5 detik
    task.spawn(function()
        while detecting and isEnabled do
            -- Selalu ambil rootPart terbaru di loop
            local c, rp = getCharacter()
            rp.CFrame = CFrame.new(finalPosition)
            task.wait(0.5)
            if detecting then
                for _, child in ipairs(c:GetChildren()) do
                    if child:IsA("Tool") then
                        onToolDetected(c, rp)
                        return
                    end
                end
            end
        end
    end)
end

-- Auto update karakter saat respawn
player.CharacterAdded:Connect(function()
    if isEnabled then
        isRunning = false
        detecting = false
        if toolConnection then toolConnection:Disconnect() toolConnection = nil end
        task.wait(1) -- tunggu karakter load dulu
        task.spawn(runSequence)
    end
end)

Tab:CreateToggle({
    Name = "Auto Perfect And Claim",
    CurrentValue = false,
    Flag = "AutoPerfectClaim",
    Callback = function(value)
        isEnabled = value
        if isEnabled then
            isRunning = false
            detecting = false
            task.spawn(runSequence)
        else
            stopAll()
        end
    end,
})

Rayfield:LoadConfiguration()
