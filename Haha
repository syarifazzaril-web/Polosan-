-- ============ FUNGSI ============
local function getNearestCoord()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil, 0 end
    local myPos = char.HumanoidRootPart.Position
    local nearest, minDist = nil, math.huge
    for _, coord in ipairs(coords) do
        local dist = (myPos - Vector3.new(coord.x, coord.y, coord.z)).Magnitude
        if dist < minDist then minDist = dist; nearest = coord end
    end
    return nearest, minDist
end

local function teleportTo(coord)
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(coord.x, coord.y + 3, coord.z)
    end
end

