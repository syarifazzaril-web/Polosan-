local lockedCoord = nil

-- Lock koordinat SEKALI saat exe
task.spawn(function()
    local char = lp.Character or lp.CharacterAdded:Wait()
    char:WaitForChild("HumanoidRootPart")

    local dist
    lockedCoord, dist = getNearestCoord()

    if lockedCoord then
        CoordName.Text = "🔒 " .. lockedCoord.name
        CoordVal.Text = string.format("X: %.2f   Z: %.2f", lockedCoord.x, lockedCoord.z)
        DistLabel.Text = string.format("%.1f stud", dist)
        LockDot.BackgroundColor3 = Color3.fromRGB(80, 220, 120)
        LockText.Text = "Terkunci ke " .. lockedCoord.name .. " — tidak akan berubah"
        LockText.TextColor3 = Color3.fromRGB(90, 170, 120)
    end
end)

-- GO Button
GoBtn.MouseButton1Click:Connect(function()
