        teleportTo(lockedCoord)
        GoBtn.Text = "✓  Teleported!"
        GoBtn.BackgroundColor3 = Color3.fromRGB(40, 180, 90)
        task.wait(0.8)
        GoBtn.Text = "GO!  ⚡  Insta TP"
        GoBtn.BackgroundColor3 = Color3.fromRGB(100, 40, 220)
    end
end)

GoBtn.MouseEnter:Connect(function()
