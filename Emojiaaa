local range = 1000
local autoBatEnabled = false

-- ===================== CORE LOGIC =====================

function getClosestEnemy()
    local closest = nil
    local shortest = math.huge

    char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char then
            local hum = v:FindFirstChildOfClass("Humanoid")
            local enemyHrp = v:FindFirstChild("HumanoidRootPart")

            if hum and hum.Health > 0 and enemyHrp then
                local dist = (hrp.Position - enemyHrp.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = v
                end
            end
        end
    end

    return closest
end

task.spawn(function()
    while task.wait(0.15) do
        if autoBatEnabled then
            char = player.Character or player.CharacterAdded:Wait()
            local tool = char:FindFirstChild("Bat") or char:FindFirstChildOfClass("Tool")
            local hrp = char:FindFirstChild("HumanoidRootPart")

            if tool and hrp and tool:FindFirstChild("Handle") then
                local enemy = getClosestEnemy()
                if enemy then
                    local enemyHrp = enemy:FindFirstChild("HumanoidRootPart")
                    if enemyHrp then
                        local dist = (hrp.Position - enemyHrp.Position).Magnitude
                        if dist <= range then
                            hrp.CFrame = CFrame.lookAt(hrp.Position, enemyHrp.Position)
                            tool:Activate()
                            firetouchinterest(tool.Handle, enemyHrp, 0)
                            firetouchinterest(tool.Handle, enemyHrp, 1)
                        end
                    end
                end
            end
        end
    end
end)

