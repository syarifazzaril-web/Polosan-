-- ===================== HELPER: Buat Toggle Row =====================

local function createToggleRow(parent, yPos, labelText)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -16, 0, 38)
    frame.Position = UDim2.new(0, 8, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(15, 15, 35)
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 7)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Color3.fromRGB(0, 60, 140)
    stroke.Thickness = 1

    local label = Instance.new("TextLabel", frame)
    label.Text = labelText
    label.Size = UDim2.new(1, -70, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220, 220, 255)
    label.TextSize = 13
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("Frame", frame)
    btn.Size = UDim2.new(0, 40, 0, 20)
    btn.Position = UDim2.new(1, -50, 0.5, -10)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame", btn)
    circle.Size = UDim2.new(0, 14, 0, 14)
    circle.Position = UDim2.new(0, 3, 0.5, -7)
    circle.BackgroundColor3 = Color3.fromRGB(130, 130, 160)
    circle.BorderSizePixel = 0
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local status = Instance.new("TextLabel", frame)
    status.Text = "OFF"
    status.Size = UDim2.new(0, 30, 0, 16)
    status.Position = UDim2.new(1, -88, 0.5, -8)
    status.BackgroundTransparency = 1
    status.TextColor3 = Color3.fromRGB(130, 130, 160)
    status.TextSize = 10
    status.Font = Enum.Font.GothamBold

    local hit = Instance.new("TextButton", frame)
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text = ""

    return {frame = frame, btn = btn, circle = circle, status = status, label = label, stroke = stroke, hit = hit}
end

local function applyVisual(t, state)
    if state then
        t.btn.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        t.circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        t.circle.Position = UDim2.new(0, 23, 0.5, -7)
        t.status.Text = "ON"
        t.status.TextColor3 = Color3.fromRGB(0, 170, 255)
        t.label.TextColor3 = Color3.fromRGB(255, 255, 255)
        t.frame.BackgroundColor3 = Color3.fromRGB(5, 20, 50)
        t.stroke.Color = Color3.fromRGB(0, 100, 255)
    else
        t.btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        t.circle.BackgroundColor3 = Color3.fromRGB(130, 130, 160)
        t.circle.Position = UDim2.new(0, 3, 0.5, -7)
        t.status.Text = "OFF"
        t.status.TextColor3 = Color3.fromRGB(130, 130, 160)
        t.label.TextColor3 = Color3.fromRGB(220, 220, 255)
        t.frame.BackgroundColor3 = Color3.fromRGB(15, 15, 35)
        t.stroke.Color = Color3.fromRGB(0, 60, 140)
    end
end

