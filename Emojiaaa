local function applyToggleVisual(state)
    if state then
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        ToggleCircle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ToggleCircle.Position = UDim2.new(0, 23, 0.5, -7)
        StatusLabel.Text = "ON"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 170, 255)
        ToggleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(5, 20, 50)
        ToggleStroke.Color = Color3.fromRGB(0, 100, 255)
    else
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        ToggleCircle.BackgroundColor3 = Color3.fromRGB(130, 130, 160)
        ToggleCircle.Position = UDim2.new(0, 3, 0.5, -7)
        StatusLabel.Text = "OFF"
        StatusLabel.TextColor3 = Color3.fromRGB(130, 130, 160)
        ToggleLabel.TextColor3 = Color3.fromRGB(220, 220, 255)
        ToggleFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 35)
        ToggleStroke.Color = Color3.fromRGB(0, 60, 140)
    end
end

