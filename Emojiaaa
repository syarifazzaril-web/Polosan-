-- Rilzz Hub GUI v2 + Auto Config
repeat task.wait() until game:IsLoaded()

local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local range = 1000
local autoBatEnabled = false
local autoStealEnabled = false
local configPath = "RilzzHub_config.txt"

-- ===================== AUTO CONFIG =====================

local function saveConfig()
    if writefile then
        local batVal = autoBatEnabled and "1" or "0"
        local stealVal = autoStealEnabled and "1" or "0"
        writefile(configPath, batVal .. "," .. stealVal)
    end
end

local function loadConfig()
    if readfile and isfile and isfile(configPath) then
        local val = readfile(configPath)
        local parts = string.split(val, ",")
        local bat = parts[1] == "1"
        local steal = parts[2] == "1"
        return bat, steal
    end
    return false, false
end

-- ===================== CORE LOGIC =====================

function getClosestEnemy()
    local closest = nil
    local shortest = math.huge
    char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char then
            local hum = v:FindFirstChildOfClass("Humanoid")
            local enemyHrp = v:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and enemyHrp then
                local dist = (hrp.Position - enemyHrp.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = v
                end
            end
        end
    end
    return closest
end

-- Auto Bat Loop
task.spawn(function()
    while task.wait(0.15) do
        if autoBatEnabled then
            char = player.Character or player.CharacterAdded:Wait()
            local tool = char:FindFirstChild("Bat") or char:FindFirstChildOfClass("Tool")
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if tool and hrp and tool:FindFirstChild("Handle") then
                local enemy = getClosestEnemy()
                if enemy then
                    local enemyHrp = enemy:FindFirstChild("HumanoidRootPart")
                    if enemyHrp then
                        local dist = (hrp.Position - enemyHrp.Position).Magnitude
                        if dist <= range then
                            hrp.CFrame = CFrame.lookAt(hrp.Position, enemyHrp.Position)
                            tool:Activate()
                            firetouchinterest(tool.Handle, enemyHrp, 0)
                            firetouchinterest(tool.Handle, enemyHrp, 1)
                        end
                    end
                end
            end
        end
    end
end)

-- Auto Steal Loop
task.spawn(function()
    while task.wait(0.3) do
        if autoStealEnabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if not autoStealEnabled then break end
                if v:IsA("ProximityPrompt") and string.lower(v.ActionText) == "steal" then
                    pcall(function()
                        v:InputHoldBegin()
                        task.wait(v.HoldDuration or 0.2)
                        v:InputHoldEnd()
                    end)
                end
            end
        end
    end
end)

