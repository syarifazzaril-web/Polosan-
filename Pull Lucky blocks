-- TAB: PULL LUCKY BLOCKS

local lib = _G.RilzHub
local LuckyBlocks = _G.LuckyBlocksTab

-- ==========================================
-- AUTO BEST LUCKY BLOCKS (TOMBOL SEKALI TEKAN)
-- ==========================================
lib:AddButton(LuckyBlocks.scroll, "Auto Best Lucky Blocks", "Primary", function()
    task.spawn(function()
        local Players = game:GetService("Players")
        local player = Players.LocalPlayer
        repeat task.wait() until player.Character
        local hrp = player.Character:WaitForChild("HumanoidRootPart")

        local friends = workspace:FindFirstChild("Live") and
                        workspace:FindFirstChild("Live"):FindFirstChild("Friends")

        if not friends then
            warn("[AutoBestLucky] Folder Friends tidak ditemukan!")
            return
        end

        local priority = {
            ["Divine Lucky Block"]        = 1,
            ["OG Lucky Block"]            = 2,
            ["Exclusive Lucky Block"]     = 3,
            ["Brainrot God Lucky Block"]  = 4,
            ["Secret Lucky Block"]        = 5,
            ["Mythic Lucky Block"]        = 6,
            ["Legendary Lucky Block"]     = 7,
            ["Epic Lucky Block"]          = 8,
            ["Rare Lucky Block"]          = 9,
            ["Common Lucky Block"]        = 10,
        }

        local function getSortedBlocks()
            local list = {}
            for _, block in pairs(friends:GetChildren()) do
                local p = priority[block.Name]
                if p then
                    table.insert(list, {block = block, p = p})
                end
            end
            table.sort(list, function(a, b) return a.p < b.p end)
            return list
        end

        local sorted = getSortedBlocks()
        if #sorted == 0 then
            warn("[AutoBestLucky] Tidak ada lucky block tersedia!")
            return
        end

        local best = sorted[1].block
        local rp = best:FindFirstChild("RootPart")
        if rp then
            local pos = rp.CFrame.Position
            hrp.CFrame = CFrame.new(pos.X, pos.Y + 5, pos.Z)
            task.wait(0.3)
            local prompt = rp:FindFirstChild("StealPrompt")
            if prompt then
                pcall(fireproximityprompt, prompt)
            end
        end
    end)
end)

-- ==========================================
-- AUTO COLLECT
-- ==========================================
lib:AddToggle(LuckyBlocks.scroll, "Auto Collect", "Otomatis collect dari plot", false, function(Value)
    _G.AutoCollectLucky = Value
    if Value then
        task.spawn(function()
            local Players = game:GetService("Players")
            local player = Players.LocalPlayer
            repeat task.wait() until player.Character
            local hrp = player.Character:WaitForChild("HumanoidRootPart")

            local plots = workspace:WaitForChild("Plots")
            local myPlot = nil
            for _, plot in pairs(plots:GetChildren()) do
                local owner = plot:FindFirstChild("owner")
                if owner and owner.Value == player.Name then
                    myPlot = plot
                    break
                end
            end

            if not myPlot then
                warn("[AutoCollect] Plot tidak ditemukan!")
                return
            end

            local function collectAll()
                repeat task.wait() until player.Character
                hrp = player.Character:WaitForChild("HumanoidRootPart")
                local collectPads = myPlot:FindFirstChild("CollectPads")
                if collectPads then
                    for _, model in pairs(collectPads:GetChildren()) do
                        if model:FindFirstChild("PurchaseInfo", true) then continue end
                        for _, obj in pairs(model:GetDescendants()) do
                            if obj:IsA("BasePart") then
                                pcall(firetouchinterest, hrp, obj, 0)
                                pcall(firetouchinterest, hrp, obj, 1)
                            end
                        end
                    end
                end
            end

            while _G.AutoCollectLucky do
                collectAll()
                task.wait(30)
            end
        end)
    end
end)

