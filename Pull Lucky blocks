-- ==========================================
-- AUTO BEST LUCKY BLOCKS (TOMBOL SEKALI TEKAN)
-- ==========================================
lib:AddButton(LuckyBlocks.scroll, "Auto Best Lucky Blocks", "Primary", function()
    task.spawn(function()
        local Players = game:GetService("Players")
        local player = Players.LocalPlayer
        repeat task.wait() until player.Character
        local hrp = player.Character:WaitForChild("HumanoidRootPart")
        local humanoid = player.Character:WaitForChild("Humanoid")
        local friends = workspace:FindFirstChild("Live") and workspace:FindFirstChild("Live"):FindFirstChild("Friends")

        if not friends then warn("[AutoBestLucky] Folder Friends tidak ditemukan!") return end

        local SPAWN = CFrame.new(197.6789514160156, 2.4594995975494385, 308.1326599121094)

        local priority = {
            ["Divine Lucky Block"]        = 1,
            ["OG Lucky Block"]            = 2,
            ["Exclusive Lucky Block"]     = 3,
            ["Brainrot God Lucky Block"]  = 4,
            ["Secret Lucky Block"]        = 5,
            ["Mythic Lucky Block"]        = 6,
            ["Legendary Lucky Block"]     = 7,
            ["Epic Lucky Block"]          = 8,
            ["Rare Lucky Block"]          = 9,
            ["Common Lucky Block"]        = 10,
        }

        local function lerpCFrame(a, b, t)
            return a:Lerp(b, t)
        end

        local function smoothFly(targetCFrame, duration)
            local startCFrame = hrp.CFrame
            local elapsed = 0
            while elapsed < duration do
                elapsed = elapsed + task.wait()
                local t = math.min(elapsed / duration, 1)
                hrp.CFrame = lerpCFrame(startCFrame, targetCFrame, t)
            end
            hrp.CFrame = targetCFrame
        end

        -- Cari block terbaik
        local bestBlock = nil
        local bestPriority = 999
        for _, block in pairs(friends:GetChildren()) do
            local p = priority[block.Name]
            if p and p < bestPriority then
                bestPriority = p
                bestBlock = block
            end
        end

        if not bestBlock then warn("[AutoBestLucky] Tidak ada lucky block!") return end

        local rp = bestBlock:FindFirstChild("RootPart")
        if not rp then warn("[AutoBestLucky] RootPart tidak ditemukan!") return end

        -- Terbang ke block
        local pos = rp.CFrame.Position
        hrp.CFrame = CFrame.new(pos.X, pos.Y + 5, pos.Z)
        task.wait(0.3)

        -- Steal
        local prompt = rp:FindFirstChild("StealPrompt")
        if prompt then
            fireproximityprompt(prompt)
            print("[AutoBestLucky] Steal: " .. bestBlock.Name)
        end

        -- Terbang balik ke spawn
        humanoid.PlatformStand = true
        smoothFly(CFrame.new(hrp.Position + Vector3.new(0, 100, 0)), 0.3)
        local spawnPos = SPAWN.Position
        smoothFly(CFrame.new(spawnPos.X, spawnPos.Y + 100, spawnPos.Z), 1)
        smoothFly(SPAWN, 0.3)
        humanoid.PlatformStand = false
        print("[AutoBestLucky] Sampai spawn!")
    end)
end)

-- ==========================================
-- AUTO COLLECT
-- ==========================================
lib:AddToggle(LuckyBlocks.scroll, "Auto Collect", "Otomatis collect dari plot", false, function(Value)
    _G.AutoCollectLucky = Value
    if Value then
        task.spawn(function()
            local Players = game:GetService("Players")
            local player = Players.LocalPlayer
            repeat task.wait() until player.Character
            local hrp = player.Character:WaitForChild("HumanoidRootPart")

            local plots = workspace:WaitForChild("Plots")
            local myPlot = nil
            for _, plot in pairs(plots:GetChildren()) do
                local owner = plot:FindFirstChild("owner")
                if owner and owner.Value == player.Name then
                    myPlot = plot
                    break
                end
            end

            if not myPlot then warn("[AutoCollect] Plot tidak ditemukan!") return end

            local function collectAll()
                repeat task.wait() until player.Character
                hrp = player.Character:WaitForChild("HumanoidRootPart")
                local collectPads = myPlot:FindFirstChild("CollectPads")
                if collectPads then
                    for _, model in pairs(collectPads:GetChildren()) do
                        if model:FindFirstChild("PurchaseInfo", true) then continue end
                        for _, obj in pairs(model:GetDescendants()) do
                            if obj:IsA("BasePart") then
                                pcall(firetouchinterest, hrp, obj, 0)
                                pcall(firetouchinterest, hrp, obj, 1)
                            end
                        end
                    end
                end
            end

            while _G.AutoCollectLucky do
                collectAll()
                task.wait(30)
            end
        end)
    end
end)

