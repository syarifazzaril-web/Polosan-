-- [ ฟังก์ชันสร้างปุ่มพื้นฐาน ]
local function AddButton(parent, text, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.BackgroundColor3 = Theme.SurfaceLight
    btn.Text = text
    btn.TextColor3 = Theme.Text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local function AddToggle(parent, text, callback)
    local enabled = false
    local btn = AddButton(parent, text .. " : OFF ❌", function()
        enabled = not enabled
        callback(enabled)
    end)
    RunService.RenderStepped:Connect(function()
        btn.Text = text .. (enabled and " : ON ✅" or " : OFF ❌")
        btn.TextColor3 = enabled and Theme.Accent or Theme.Text
    end)
    return btn
end

local function CreateAdjuster(parent, title, min, max, step, defaultVal, callback)
    local val = defaultVal
    callback(val)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(1, -20, 0, 45)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 15)
    label.Text = title .. ": " .. val
    label.TextColor3 = Theme.TextDim
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 11

    local minus = Instance.new("TextButton", frame)
    minus.Text = "-"
    minus.Size = UDim2.new(0, 35, 0, 25)
    minus.Position = UDim2.new(0.1, 0, 0.4, 0)
    minus.BackgroundColor3 = Theme.SurfaceLight
    minus.TextColor3 = Theme.Text
    Instance.new("UICorner", minus).CornerRadius = UDim.new(0, 4)

    local plus = Instance.new("TextButton", frame)
    plus.Text = "+"
    plus.Size = UDim2.new(0, 35, 0, 25)
    plus.Position = UDim2.new(0.9, -35, 0.4, 0)
    plus.BackgroundColor3 = Theme.SurfaceLight
    plus.TextColor3 = Theme.Text
    Instance.new("UICorner", plus).CornerRadius = UDim.new(0, 4)

    minus.MouseButton1Click:Connect(function()
        val = math.max(min, val - step)
        label.Text = title .. ": " .. val
        callback(val)
    end)
    plus.MouseButton1Click:Connect(function()
        val = math.min(max, val + step)
        label.Text = title .. ": " .. val
        callback(val)
    end)
end

