local function makeCard(cfg, scanFn, order)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(1, -32, 0, 92)
    Card.BackgroundColor3 = Color3.fromRGB(18, 12, 32)
    Card.BorderSizePixel = 0
    Card.LayoutOrder = order
    Card.Parent = ScrollFrame
    Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 10)
    local CS = Instance.new("UIStroke", Card)
    CS.Color = cfg.stroke
    CS.Thickness = 1
    CS.Transparency = 0.5

    local CardTitle = Instance.new("TextLabel")
    CardTitle.Size = UDim2.new(0, 180, 0, 22)
    CardTitle.Position = UDim2.new(0, 12, 0, 7)
    CardTitle.BackgroundTransparency = 1
    CardTitle.Text = cfg.icon .. "  " .. cfg.name
    CardTitle.TextColor3 = cfg.color1
    CardTitle.Font = Enum.Font.GothamBold
    CardTitle.TextSize = 14
    CardTitle.TextXAlignment = Enum.TextXAlignment.Left
    CardTitle.Parent = Card

    local CountLabel = Instance.new("TextLabel")
    CountLabel.Size = UDim2.new(0, 80, 0, 20)
    CountLabel.Position = UDim2.new(1, -90, 0, 8)
    CountLabel.BackgroundTransparency = 1
    CountLabel.Text = "0 found"
    CountLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
    CountLabel.Font = Enum.Font.Gotham
    CountLabel.TextSize = 10
    CountLabel.TextXAlignment = Enum.TextXAlignment.Right
    CountLabel.Parent = Card

    local MiniStatus = Instance.new("TextLabel")
    MiniStatus.Size = UDim2.new(1, -16, 0, 16)
    MiniStatus.Position = UDim2.new(0, 12, 0, 32)
    MiniStatus.BackgroundTransparency = 1
    MiniStatus.Text = "Tidak ada brainrot " .. cfg.label .. " di map"
    MiniStatus.TextColor3 = Color3.fromRGB(180, 80, 80)
    MiniStatus.Font = Enum.Font.Gotham
    MiniStatus.TextSize = 10
    MiniStatus.TextXAlignment = Enum.TextXAlignment.Left
    MiniStatus.Parent = Card

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -16, 0, 26)
    Btn.Position = UDim2.new(0, 8, 0, 58)
    Btn.BackgroundColor3 = Color3.fromRGB(30, 20, 55)
    Btn.Text = "▶  START"
    Btn.TextColor3 = cfg.color1
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 12
    Btn.BorderSizePixel = 0
    Btn.Parent = Card
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
    local BS = Instance.new("UIStroke", Btn)
    BS.Color = cfg.stroke
    BS.Thickness = 1
    BS.Transparency = 0.4

    local key = cfg.name
    loops[key] = false

    Btn.MouseButton1Click:Connect(function()
        loops[key] = not loops[key]

        if loops[key] then
            Btn.Text = "⏹  STOP"
            Btn.BackgroundColor3 = Color3.fromRGB(20, 60, 25)
            MiniStatus.Text = "🔍 Mencari " .. cfg.label .. "..."
            MiniStatus.TextColor3 = Color3.fromRGB(160, 160, 160)

            task.spawn(function()
                while loops[key] do
                    local results = scanFn()
                    CountLabel.Text = #results .. " found"

                    if #results > 0 then
                        local char = lp.Character
                        local nearest = results[1]
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            local myPos = char.HumanoidRootPart.Position
                            local minDist = math.huge
                            for _, r in ipairs(results) do
                                local d = (myPos - r.pos).Magnitude
                                if d < minDist then minDist = d; nearest = r end
                            end
                        end

                        MiniStatus.Text = "⚡ TP ke " .. nearest.name
                        MiniStatus.TextColor3 = cfg.color1
                        teleportTo(nearest.pos)
                        task.wait(0.4)

                        if nearest.prompt and nearest.prompt.Parent then
                            fireSteal(nearest.prompt)
                            MiniStatus.Text = "✅ Steal: " .. nearest.name
                            MiniStatus.TextColor3 = Color3.fromRGB(80, 220, 120)
                        end

                        -- FIXED: TP balik ke HOME setelah steal
                        task.wait(0.5)
                        teleportTo(HOME_POS)
                        MiniStatus.Text = "🏠 Kembali ke home..."
                        MiniStatus.TextColor3 = Color3.fromRGB(160, 200, 255)
                        task.wait(0.8)
                    else
                        CountLabel.Text = "0 found"
                        MiniStatus.Text = "Tidak ada brainrot " .. cfg.label .. " di map"
                        MiniStatus.TextColor3 = Color3.fromRGB(180, 80, 80)
                        task.wait(1)
                    end
                end

                MiniStatus.Text = "Tidak ada brainrot " .. cfg.label .. " di map"
                MiniStatus.TextColor3 = Color3.fromRGB(180, 80, 80)
                CountLabel.Text = "0 found"
            end)
        else
            Btn.Text = "▶  START"
            Btn.BackgroundColor3 = Color3.fromRGB(30, 20, 55)
            MiniStatus.Text = "Tidak ada brainrot " .. cfg.label .. " di map"
            MiniStatus.TextColor3 = Color3.fromRGB(180, 80, 80)
            CountLabel.Text = "0 found"
        end
    end)
end

