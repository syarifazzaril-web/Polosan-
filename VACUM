local function teleportTo(pos)
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
    end
end

local function fireSteal(prompt)
    pcall(function() fireproximityprompt(prompt) end)
end

local function scanByRarity(rarity)
    local found = {}
    local ef = workspace:FindFirstChild("EntitiesFolder")
    if not ef then return found end
    for _, v in ipairs(ef:GetDescendants()) do
        if v.Name == "RarityLabel" and v:IsA("TextLabel") and string.lower(v.Text) == string.lower(rarity) then
            local mesh = v.Parent and v.Parent.Parent
            if mesh and mesh:IsA("BasePart") then
                local prompt = mesh:FindFirstChild("ProximityPrompt")
                if prompt then
                    table.insert(found, {name = mesh.Parent and mesh.Parent.Name or mesh.Name, pos = mesh.Position, prompt = prompt})
                end
            end
        end
    end
    return found
end

-- FIXED: Scan mutation di EntitiesFolder bukan Plots
local function scanByMutation(mutation)
    local found = {}
    local ef = workspace:FindFirstChild("EntitiesFolder")
    if not ef then
        -- fallback ke Plots kalau EntitiesFolder tidak ada
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return found end
        for _, v in ipairs(plots:GetDescendants()) do
            if v.Name == "MutationLabel" and v:IsA("TextLabel") and string.lower(v.Text) == string.lower(mutation) then
                local mesh = v.Parent and v.Parent.Parent
                if mesh and mesh:IsA("BasePart") then
                    local prompt = mesh:FindFirstChild("ProximityPrompt")
                    if prompt then
                        table.insert(found, {name = mesh.Parent and mesh.Parent.Name or mesh.Name, pos = mesh.Position, prompt = prompt})
                    end
                end
            end
        end
        return found
    end
    for _, v in ipairs(ef:GetDescendants()) do
        if v.Name == "MutationLabel" and v:IsA("TextLabel") and string.lower(v.Text) == string.lower(mutation) then
            local mesh = v.Parent and v.Parent.Parent
            if mesh and mesh:IsA("BasePart") then
                local prompt = mesh:FindFirstChild("ProximityPrompt")
                if prompt then
                    table.insert(found, {name = mesh.Parent and mesh.Parent.Name or mesh.Name, pos = mesh.Position, prompt = prompt})
                end
            end
        end
    end
    return found
end

