    "fairy_luckyblock",
}

local suffixTable = {
    K  = 1000,
    M  = 1000000,
    B  = 1000000000,
    T  = 999999995904,
    Qa = 999999986991104,
    Qi = 1000000000000000000,
    Sx = 1e+21,
    Sp = 1e+24,
    Oc = 1e+27,
    No = 1e+30,
    Dc = 1e+33,
}

local function parseCash(text)
    text = text:gsub("%$", ""):gsub(",", ""):gsub("%s+", "")
    local num = tonumber(text:match("[%d%.]+"))
    local suf = text:match("%a+")
    if not num then return 0 end
    if suf and suffixTable[suf] then
        return num * suffixTable[suf]
    end
    return num
end

local ablRunning = false
Tabs.Main:CreateToggle({
    Name = "Auto Buy Best Luckyblock",
    CurrentValue = false,
    Flag = "ABL",
