lib:AddButton(LuckyBe.scroll, "Dupe", "Klik untuk dupe", function()
    repeat task.wait() until game:IsLoaded()

    local Players = game:GetService("Players")
    local player = Players.LocalPlayer

    local bases = {
        Vector3.new(-47.4004058378906, 5.335516452789307, 28.480764389038086),
        Vector3.new(-102.54472351074219, 5.260526180267334, 29.12882423040879),
        Vector3.new(-156.66241455078125, 5.3355278968811035, 31.05963897705078),
        Vector3.new(-212.40399169921875, 5.298027515411377, 29.95789337158203)
    }

    local function getHRP()
        local char = player.Character or player.CharacterAdded:Wait()
        return char:WaitForChild("HumanoidRootPart")
    end

    local hrp = getHRP()

    local lockedBase
    local shortest = math.huge

    for _, pos in ipairs(bases) do
        local dist = (hrp.Position - pos).Magnitude
        if dist < shortest then
            shortest = dist
            lockedBase = pos
        end
    end

    print("Base locked:", lockedBase)
    hrp.CFrame = CFrame.new(lockedBase)
    task.wait(0.15)

    local closestPrompt
    local distance = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local part = v.Parent
            if part and part:IsA("BasePart") then
                local dist = (hrp.Position - part.Position).Magnitude
                if dist < distance then
                    distance = dist
                    closestPrompt = v
                end
            end
        end
    end

    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = 0
    end

    if closestPrompt then
        fireproximityprompt(closestPrompt, 0)
        fireproximityprompt(closestPrompt, 0)
        fireproximityprompt(closestPrompt, 0)
    end
end)

lib:AddToggle(LuckyBe.scroll, "Auto Brainrot", "Otomatis teleport farming brainrot", false, function(Value)
    _autoTP = Value
    if Value then
        task.spawn(function()
            local Players = game:GetService("Players")
            local player = Players.LocalPlayer

            local function getHRP()
                local char = player.Character or player.CharacterAdded:Wait()
                return char:WaitForChild("HumanoidRootPart")
            end

            local posA = CFrame.new(
                -106.86107635498047,
                13.407323837280273,
                -1244.5692138671875
            )

            local posB = CFrame.new(
                -109.15310668945312,
                4.49802827835083,
                -47.55513000488281
            )

            while _autoTP do
                getHRP().CFrame = posA
                task.wait(1)
                if not _autoTP then break end

                getHRP().CFrame = posA
                task.wait(10)
                if not _autoTP then break end

                getHRP().CFrame = posB
                task.wait(1)
            end
        end)
    end
end)

